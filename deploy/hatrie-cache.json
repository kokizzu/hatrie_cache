{
  "monitoring_server": true,
  "monitoring_addr": "127.0.0.1:8080",
  "monitoring_web_dir": "svelte-mpa/dist",
  "audit_log_path": "data/audit.jsonl",
  "write_protection": true,
  "rate_limit": 100,
  "key_stats_mode": "bounded",
  "key_stats_capacity": 100000,
  "node_id": "node-a",
  "topology_path": "deploy/topology/full-replica.json",
  "snapshot_path": "data/snapshot.hc",
  "snapshot_interval": "30s",
  "snapshot_format": "gzip-best-binary",
  "journal_path": "data/commands.journal",
  "journal_format": "binary",
  "journal_pull_state_path": "data/commands.journal.pull_state.json",
  "db_path": "data/cache.leveldb",
  "db_format": "binary",
  "db_sync_interval": "30s",
  "db_compact_interval": "10m",
  "db_hot_load": true,
  "db_hot_load_max_bytes": 4096,
  "replication": true,
  "replication_mode": "command",
  "replication_async": true,
  "replication_outbox_path": "data/replication-outbox.leveldb",
  "replication_outbox_format": "leveldb",
  "replication_wire_format": "protobuf"
}
